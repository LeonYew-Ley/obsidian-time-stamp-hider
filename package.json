{
  "name": "time-stamp-hider",
  "version": "1.0.3",
  "description": "Obsidian plugin that hides timestamp prefixes in Zettelkasten-style internal link display text.",
  "main": "main.js",
  "scripts": {
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "lint": "eslint main.ts"
  },
  "keywords": [
    "obsidian",
    "zettelkasten",
    "timestamp"
  ],
  "author": "LeonYew-Ley",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "^6.38.1",
    "@typescript-eslint/parser": "^8.61.1",
    "esbuild": "^0.25.5",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.3"
  }
}
